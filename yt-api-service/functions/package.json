{
  "name": "functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions,auth,firestore",
    "start": "npm run serve",
    "deploy": "firebase deploy --only functions",
    "deploy:create-user": "firebase deploy --only functions:createUser",
    "deploy:generate-upload-url": "firebase deploy --only functions:generateUploadUrl",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "firebase-admin": "^13.6.1",
    "firebase-functions": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.7.0"
  }
}
